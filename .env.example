# ────────────────────────────────────────────
#  ZONBAT · Variables de entorno
#  Copia este archivo como .env y completa
# ────────────────────────────────────────────

PORT=3000

# Google OAuth2 (crea credenciales en console.cloud.google.com)
GOOGLE_CLIENT_ID=tu_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_REFRESH_TOKEN=tu_refresh_token_aqui   # obtenido en /auth → /oauth2callback

# ID del calendario donde se crearán los eventos
# 'primary' = calendario principal de la cuenta
# O el ID específico de tu calendario de Sound Healing
ZONBAT_CALENDAR_ID=primary
ZONBAT_CALENDAR_EMAIL=sound-healing@tudominio.com

# Email para enviar confirmaciones (Gmail)
EMAIL_USER=tucorreo@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx   # App Password de Google (no tu contraseña normal)
